  const resultsDiv = document.getElementById('results');
  const searchBar = document.getElementById('searchBar');

  // Visually formats the internal notes for the UI
  function formatForDisplay(text) {
    const regex = /<div class="internal-note">.*?<\/div>/gs;
    // We already styled the notes natively in the string, no replacement needed for visual display here.
    return text;
  }

  // Renders the list based on search
  function renderCards(filterText = '') {
    resultsDiv.innerHTML = '';
    const lowerFilter = filterText.toLowerCase();

    quickReplies.forEach((reply, index) => {
      if (reply.title.toLowerCase().includes(lowerFilter)) {
        
        const isOpen = filterText.length > 0 ? 'open' : '';
        const card = document.createElement('details');
        card.className = 'reply-card';
        if (isOpen) card.setAttribute('open', '');
        
        card.innerHTML = `
          <summary class="reply-title">
            <span class="title-text">${reply.title}</span>
            <button class="copy-btn" id="btn-${index}" onclick="copyRichText(event, ${index}, 'btn-${index}')">Copy</button>
          </summary>
          <div class="reply-content">
            <div class="text-box">${formatForDisplay(reply.thai)}</div>
          </div>
        `;
        resultsDiv.appendChild(card);
      }
    });
  }

  // NEW COPY FUNCTION: Grabs native HTML formatting to paste as Rich Text
  function copyRichText(event, dataIndex, btnId) {
    // Prevent the accordion from opening/closing when we click the button
    event.stopPropagation();
    event.preventDefault();

    let htmlContent = quickReplies[dataIndex].thai;
    
    // Strip out the internal notes completely using regex so it doesn't copy to the customer
    const removeNotesRegex = /<div class="internal-note">.*?<\/div>/gs;
    htmlContent = htmlContent.replace(removeNotesRegex, '').trim();

    // The Sandbox Bypass: Create an invisible DIV
    const tempDiv = document.createElement("div");
    tempDiv.innerHTML = htmlContent;
    tempDiv.style.position = "absolute";
    tempDiv.style.left = "-9999px";
    
    document.body.appendChild(tempDiv);

    // Select the rich text contents inside the div
    const range = document.createRange();
    range.selectNodeContents(tempDiv);
    const selection = window.getSelection();
    selection.removeAllRanges();
    selection.addRange(range);

    try {
      // Execute standard copy command
      document.execCommand('copy');
      
      // Visual success confirmation
      const btn = document.getElementById(btnId);
      const originalText = btn.innerText;
      btn.innerText = "✓ Copied!";
      btn.classList.add("copied");
      
      setTimeout(() => {
        btn.innerText = originalText;
        btn.classList.remove("copied");
      }, 1500);
    } catch (err) {
      alert("Copy failed. Your browser may be blocking scripts in Google Sites.");
    }

    // Cleanup selection and delete the invisible div
    selection.removeAllRanges();
    document.body.removeChild(tempDiv);
  }

  // Search event listener
  searchBar.addEventListener('input', (e) => {
    renderCards(e.target.value);
  });

  // Load everything on start
  renderCards();
</script>

